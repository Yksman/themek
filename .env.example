# Database
# 운영은 Postgres 권장 — 이 walking skeleton은 SQLite로 시작.
# Postgres 사용 시: postgresql+psycopg://themek:themek@localhost:5432/themek
POSTGRES_DSN=sqlite:///./themek.db

# Logging
LOG_LEVEL=INFO

# Claude CLI
# Claude Code must be installed and authenticated separately (claude login).
# No API key needed when using subscription.
CLAUDE_CLI_BIN=claude
CLAUDE_CLI_TIMEOUT_SEC=120

# DART OpenAPI
# https://opendart.fss.or.kr/intro/main.do 에서 발급
DART_API_KEY=
DART_CACHE_DIR=data/dart
DART_RATE_PER_MIN=60
DART_HTTP_TIMEOUT_SEC=60
